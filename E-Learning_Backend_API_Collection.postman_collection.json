            },
            "url": { "raw": "{{base_url}}/api/users/profile/image/", "host": ["{{base_url}}"], "path": ["api", "users", "profile", "image", ""] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"Test@12345\",\n  \"new_password\": \"NewPass@123\",\n  \"confirm_password\": \"NewPass@123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/users/profile/change-password/", "host": ["{{base_url}}"], "path": ["api", "users", "profile", "change-password", ""] }
          }
        },
        {
          "name": "Profile Statistics",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/users/profile/statistics/", "host": ["{{base_url}}"], "path": ["api", "users", "profile", "statistics", ""] }
          }
        },
